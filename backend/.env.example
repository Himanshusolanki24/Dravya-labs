# =====================================================
# Dravya Labs Backend — Environment Configuration
# =====================================================

# ── Security ──
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# ── Supabase ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Helix DB (AI Memory Store — replaces Pinecone) ──
HELIX_DB_API_KEY=your-helix-db-api-key-here
HELIX_DB_API_URL=http://localhost:8080
HELIX_DB_COLLECTION=dravya-health-profiles

# ── Redis Cache ──
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ──
MISTRAL_API_KEY=your-mistral-api-key-here
MODEL_NAME=mistral-large-latest

# Optional — enables multi-provider routing/voting
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Multi-LLM Routing ──
LLM_SIMPLE_MODEL=mistral-small-latest
LLM_COMPLEX_MODEL=mistral-large-latest
LLM_ENSEMBLE_MODELS=mistral-large-latest,gpt-4o,claude-sonnet-5
LLM_JUDGE_MODEL=mistral-small-latest

# ── Feature Flags ──
USE_HIERARCHICAL_ORCHESTRATOR=true
MAX_CRITIC_RETRIES=3

# ── Embeddings ──
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ── ML Microservice URLs (blank = client returns "unavailable") ──
SKIN_MODEL_API_URL=
HAIR_MODEL_API_URL=
PCOS_MODEL_API_URL=
DIABETES_MODEL_API_URL=
AUTOIMMUNE_MODEL_API_URL=http://localhost:8003/predict
OBESITY_MODEL_API_URL=
BRAHMA_MODEL_API_URL=http://localhost:8005/predict
DIETPLAIN_MODEL_API_URL=http://localhost:8004/predict
HERBS_MODEL_API_URL=http://localhost:8002/predict
SYMPTOM_TREATMENT_MODEL_API_URL=http://localhost:8006/predict
MODEL_CLIENTS_TIMEOUT=30

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=False