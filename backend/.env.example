# =====================================================
# Azure AI Foundry Configuration
# =====================================================
# Get your credentials from Azure AI Foundry: https://ai.azure.com
# Navigate to your project > Models > Select your deployed model > Get API key

# Option 1: Azure AI Foundry (Model-as-a-Service)
# Format: https://<your-project-name>.services.ai.azure.com/models
AZURE_MISTRAL_ENDPOINT=https://your-project.services.ai.azure.com/models
AZURE_API_KEY=your-azure-ai-foundry-api-key-here
MODEL_NAME=mistral-large

# Option 2: Azure OpenAI Service
# Format: https://<your-resource>.openai.azure.com/openai/deployments/<deployment-name>
# AZURE_MISTRAL_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# AZURE_API_KEY=your-azure-openai-api-key
MISTRAL_KEY = NwZTyN9yKnrsAuCpiNC6urPN98DCvxdG

# =====================================================
# Database Configuration
# =====================================================
# Azure PostgreSQL Flexible Server
DATABASE_URL=postgresql://username:password@your-server.postgres.database.azure.com:5432/dravya_labs

# Full format with SSL (recommended for Azure):
# DATABASE_URL=postgresql://username%40servername:password@servername.postgres.database.azure.com:5432/database_name?sslmode=require

# =====================================================
# Server Configuration
# =====================================================
HOST=0.0.0.0
PORT=8000
DEBUG=False